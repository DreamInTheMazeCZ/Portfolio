# ===== Airflow 런타임 =====
# 컨테이너가 마운트된 볼륨(logs/data 등)에 쓸 때 사용할 호스트 UID.
# Linux/Mac: 터미널에서 `id -u` 값으로 설정. Windows(Docker Desktop)는 50000 권장.
AIRFLOW_UID=50000

# 웹 UI 관리자 계정
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ===== 컨테이너 내 작업 경로 (보통 수정 불필요) =====
PDF_DIR=/opt/airflow/data/pdf_folder
BASE_DIR=/opt/airflow/data/extraction

# ===== GPT =====
GPT_API_KEY=GPT API key
GPT_MODEL_NAME=GPT model name

# ===== 데이터 저장용 외부 PostgreSQL =====
# 호스트(로컬 PC)에서 도는 DB라면 DB_HOST=host.docker.internal
DB_HOST=host.docker.internal
DB_NAME=db name
DB_USER=db user id
DB_PW=db password
DB_PORT=5432

# ===== 이미지 URL (적재 시 image_path 접두사) =====
IMG_URL=image url

# ===== GPT 비동기 동시 요청 수 =====
MAX_CONCURRENT_REQUESTS=3
